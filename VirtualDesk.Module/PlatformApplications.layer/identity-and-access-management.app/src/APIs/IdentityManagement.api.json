{
	"name": "IdentityManagement",
	"endpoints": [
		{
			"path": "/user/check-exist",
			"method": "POST",
			"summary": "CheckUserExist",
			"parameters": [
				{
					"name": "username",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "email",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"path": "/user/verify-password",
			"method": "POST",
			"summary": "VerifyPasswordAndGetUser",
			"parameters": [
				{
					"name": "username",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "password",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		}
	]
}