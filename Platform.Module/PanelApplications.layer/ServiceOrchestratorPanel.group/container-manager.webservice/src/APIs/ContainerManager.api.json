{
	"name": "ContainerManager",
	"endpoints": [
		{
			"path": "/containers",
			"method": "GET",
			"summary": "ListContainers"
		},
		{
			"path": "/images",
			"method": "GET",
			"summary": "ListImages"
		},
		{
			"path": "/networks",
			"method": "GET",
			"summary": "ListNetworks"
		},
		{
			"path": "/volumes",
			"method": "GET",
			"summary": "ListVolumes"
		},
		{
			"summary": "RemoveContainer",
			"method": "POST",
			"path": "/remove-container",
			"parameters": [
				{
					"in": "body",
					"name": "containerIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "StartContainer",
			"method": "POST",
			"path": "/start-container",
			"parameters": [
				{
					"in": "body",
					"name": "containerIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "StopContainer",
			"method": "POST",
			"path": "/stop-container",
			"parameters": [
				{
					"in": "body",
					"name": "containerIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "InspectContainer",
			"method": "POST",
			"path": "/inspect-container",
			"parameters": [
				{
					"in": "body",
					"name": "containerIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "GetContainerLogHistory",
			"method": "POST",
			"path": "/container-log-history",
			"parameters": [
				{
					"in": "body",
					"name": "containerIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "InspectNetwork",
			"method": "POST",
			"path": "/inspect-details",
			"parameters": [
				{
					"in": "body",
					"name": "networkIdOrName",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "CreateNewNetwork",
			"method": "POST",
			"path": "/create-network",
			"parameters": [
				{
					"in": "body",
					"name": "options",
					"type": "json",
					"required": true
				}
			]
		}
	]
}