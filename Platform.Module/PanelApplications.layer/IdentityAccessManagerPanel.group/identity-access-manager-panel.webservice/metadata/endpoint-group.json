{
    "bound-params":[ "serverService", "commandExecutorLib" ],
    "params": [ 
        "iamManagerServerManagerUrl", 
        "iamManagerSocketPath" 
    ],
    "endpoints": [
        {
            "url": "/users",
            "type": "controller",
            "params": {
                "api-template": "APIs/Users.api.json",
                "controller": "Controllers/Users.controller",
                "controller-params":{
                    "iamManagerServerManagerUrl":"{{iamManagerServerManagerUrl}}",
                    "iamManagerSocketPath":"{{iamManagerSocketPath}}"
                }
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params":{
                    "commandExecutorLib":"commandExecutorLib"
                }
            }
        },
        {
            "url": "/organizations",
            "type": "controller",
            "params": {
                "api-template": "APIs/Organizations.api.json",
                "controller": "Controllers/Organizations.controller",
                "controller-params":{
                    "iamManagerServerManagerUrl":"{{iamManagerServerManagerUrl}}",
                    "iamManagerSocketPath":"{{iamManagerSocketPath}}"
                }
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params":{
                    "commandExecutorLib":"commandExecutorLib"
                }
            }
        } 
    ]
}