{
    "bound-params":[
        "serverService",
        "iamManagerService",
        "userManagerService",
        "organizationManagerService"
    ],
    "endpoints": [
        {
            "url": "/identity-management",
            "type": "controller",
            "params": {
                "api-template": "APIs/IdentityManagement.api.json",
                "controller": "Controllers/IdentityManagement.controller"
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params":{
                    "iamManagerService":"iamManagerService"
                }
            }
        },
        {
            "url": "/users",
            "type": "controller",
            "params": {
                "api-template": "APIs/UserManagement.api.json",
                "controller": "Controllers/UserManagement.controller"
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params":{
                    "userManagerService":"userManagerService"
                }
            }
        },
        {
            "url": "/organizations",
            "type": "controller",
            "params": {
                "api-template": "APIs/OrganizationManagement.api.json",
                "controller": "Controllers/OrganizationManagement.controller"
            },
            "bound-params": {
                "serverService":"serverService",
                "controller-params":{
                    "organizationManagerService":"organizationManagerService"
                }
            }
        }
    ]
