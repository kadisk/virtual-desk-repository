{
    "serviceName": "repository-manager-panel",
    "serviceDescription": "Painel de administração de Repositórios",
    "repositoryNamespace": "VirtualDeskRepo",
    "packageName": "repository-manager-panel",
    "packageType": "webapp",
    "packagePath": "Platform.Module/PanelApplications.layer/RepositoryManagerPanel.group/repository-manager-panel.webapp",
    "startupParams": {
        "port"                              : "7006",
        "serverName"                        : "RepositoryManagerPanelWebAppInstance",
        "serverManagerUrl"                  : "http://repository-manager-panel.app.local:9000/server-manager/status",
        "RT_ENV_GENERATED_DIR_NAME"         : ".generated_data",
        "isWatch"                           : true,
        "repositoryStorageServerManagerUrl" : "/server-manager/status"
    },
    "hostMountParams":{
        "repositoryStorageSocketPath" : "repository-storage-manager-socket",
        "uploadDirPath" : "repository-manager-repositories-storage"
    },
    "ports": [],
    "networkmode": "host"
}