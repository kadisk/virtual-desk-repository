{
    "serviceName": "service-panel",
    "serviceDescription": "Painel de Administração de serviços em execução",
    "repositoryNamespace": "VirtualDeskRepo",
    "packageName": "service-orchestrator-panel",
    "packageType": "webapp",
    "packagePath": "Platform.Module/PanelApplications.layer/ServiceOrchestratorPanel.group/service-orchestrator-panel.webapp",
    "startupParams": {
        "port"                                : "8545",
        "serverName"                          : "ServiceOrchestratorPanelWebAppInstance",
        "serverManagerUrl"                    : "http://service-panel.app.local:9000/server-manager/status",
        "RT_ENV_GENERATED_DIR_NAME"           : ".generated_data",
        "isWatch"                             : true,
        "serviceOrchestratorServerManagerUrl" : "/server-manager/status",
        "repositoryStorageServerManagerUrl"   : "/server-manager/status"
    },
    "socketParams":{
        "serviceOrchestratorSocketPath" : "service-orchestrator.app.sock",
        "repositoryStorageSocketPath": "repository-storage-manager.app.sock"
    },
    "storageParams":{
        "myServicesRepositoriesUploadDirPath" : "my-services-uploded-repositories"
    },
    "ports": [],
    "networkmode": "host"
}