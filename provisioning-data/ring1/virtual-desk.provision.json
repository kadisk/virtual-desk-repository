{
    "serviceName": "virtual-desk",
    "serviceDescription": "Painel de controle da plataforma VirtualDesk",
    "repositoryNamespace": "VirtualDeskRepo",
    "packageName": "virtual-desk",
    "packageType": "webapp",
    "packagePath": "Platform.Module/Applications.layer/virtual-desk.webapp",
    "startupParams": {
        "port"                              : "7001",
        "serverName"                        : "KadiskVirtualDeskWebAppInstance",
        "serverManagerUrl"                  : "http://virtualdesk.app.local:9000/server-manager/status",
        "RT_ENV_GENERATED_DIR_NAME"         : ".generated_data",
        "isWatch"                           : true,
        "installDataDirPath"                : "~/EcosystemData",
        "ecosystemDefaultsFileRelativePath" : "./config-files/ecosystem-defaults.json",
        "secretKey"                         : "kajsdhfg&(#Ndg",
        "repositoryStorageServerManagerUrl" : "/server-manager/status",
        "iamStorageServerManagerUrl"        : "/server-manager/status"
    },
    "hostMountParams": {
        "repositoryStorageSocketPath": "repository-storage-manager-socket"
    },
    "socketParams":{
        "iamStorageSocketPath": "iam-socket"
    },
    "storageParams":{
        "eventManagerServiceStorageFilePath" : {
            "namespace": "event-manager-service-database-file",
            "filename": "event-manager-service.sqlite",
            "owner": true
        },
        "instanceMonitoringManagerServiceStorageFilePath": {
            "namespace": "instance-monitoring-manager-service-database-file",
            "filename": "instance-monitoring-manager-service.sqlite",
            "owner": true
        },
        "uploadDirPath": {
            "namespace": "my-workbench-repositories-storage",
            "owner": true
        }
    },
    "ports": [],
    "networkmode": "host"
}